FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     pisoFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         0.3;

deltaT          1e-05;

writeControl    adjustableRunTime;

writeInterval   1e-3;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{
    TbulkOutlet
    {
        type            surfaceFieldValue;
        libs            (fieldFunctionObjects);
        fields          (T);  // (<field1> <field2> ... <fieldN>);
        regionType      patch;
        name            outlet;  // name of the patch
        operation       weightedAreaAverage;
    }
}

