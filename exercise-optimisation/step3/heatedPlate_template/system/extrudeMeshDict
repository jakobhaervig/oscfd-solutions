FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      extrudeMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


constructFrom patch;
sourceCase ".";

sourcePatches (back);
exposedPatchName front;

extrudeModel  plane;
thickness     0.001;

flipNormals false;
mergeFaces false;


