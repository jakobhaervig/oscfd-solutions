FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 14.855;

boundaryField
{
    inlet
    {
        type            turbulentMixingLengthDissipationRateInlet;
        mixingLength    0.01;
        value           uniform 14.855;
    }

    outlet
    {
        type            zeroGradient;
    }

    ".*Wall"
    {
        type            epsilonWallFunction;
        value           uniform 14.855;
    }

    "front|back"
    {
        type            epsilonWallFunction;
        value           uniform 14.855;
    }
}


